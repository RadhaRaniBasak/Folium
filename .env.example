# Server
PORT=3001
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/folium

# Redis
REDIS_URL=redis://localhost:6379

# JWT
# IMPORTANT: Replace with cryptographically secure random strings in production.
# Minimum 32 characters recommended. Example: openssl rand -hex 32
JWT_SECRET=change_me_super_secret_jwt_key
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key

# CORS
CLIENT_URL=http://localhost:5173


# ─── Production notes (Render) ────────────────────────────────────────────────
# PORT        → set automatically by Render; do NOT set manually
# NODE_ENV    → set to "production" in Render environment variables
# MONGO_URI   → MongoDB Atlas connection string (mongodb+srv://...)
# REDIS_URL   → Render Redis or Upstash URL (redis:// or rediss://)
# JWT_SECRET  → secure random string (openssl rand -hex 32)
# JWT_REFRESH_SECRET → different secure random string
# CLIENT_URL  → your Vercel frontend URL (https://<your-project>.vercel.app)
